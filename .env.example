# UGA - Program-Client Matching Engine
# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# Zoho CRM API Credentials
# ============================================
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_REFRESH_TOKEN=your_refresh_token_here
ZOHO_ACCESS_TOKEN=your_access_token_here
ZOHO_API_DOMAIN=https://www.zohoapis.com

# ============================================
# Claude API
# ============================================
ANTHROPIC_API_KEY=your_claude_api_key_here

# ============================================
# Application Settings
# ============================================
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# File Paths
# ============================================
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# ============================================
# Email Configuration (Future Phase)
# ============================================
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_email_password
# EMAIL_FROM=noreply@prism.com
# EMAIL_TO_ELIAS=elias.tacher@example.com

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your_api_key_for_authentication

# ============================================
# Zoho Workdrive (Future Phase)
# ============================================
# ZOHO_WORKDRIVE_FOLDER_ID=your_folder_id
# ZOHO_WORKDRIVE_POLL_INTERVAL=3600

# ============================================
# Scheduler (Future Phase)
# ============================================
# SCHEDULER_ENABLED=false
# SCHEDULER_CRON=0 2 * * *

# ============================================
# Branding
# ============================================
COMPANY_NAME_PRISM=Prism
COMPANY_NAME_UGA=United Grants of America
